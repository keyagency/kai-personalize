# Kai Personalize Add-on Configuration

# Master kill switch - set to false to completely disable the addon
KAI_PERSONALIZE_ENABLED=true

# Feature toggles
KAI_PERSONALIZE_FINGERPRINTING=true
KAI_PERSONALIZE_IP_TRACKING=true
KAI_PERSONALIZE_GEOLOCATION=true
KAI_PERSONALIZE_BEHAVIORAL_TRACKING=true
KAI_PERSONALIZE_EXTERNAL_DATA=true

# API Keys for external services
GEOLOCATION_API_KEY=
WEATHER_API_KEY=
NEWS_API_KEY=
EXCHANGE_API_KEY=

# MaxMind GeoIP2 Local Database Configuration
# Download free GeoLite2 databases from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Place .mmdb files in storage/app/geoip/
KAI_MAXMIND_ENABLED=true
KAI_MAXMIND_CITY_DB=app/geoip/GeoLite2-City.mmdb
KAI_MAXMIND_COUNTRY_DB=app/geoip/GeoLite2-Country.mmdb
KAI_MAXMIND_ASN_DB=app/geoip/GeoLite2-ASN.mmdb
KAI_MAXMIND_CACHE=86400
# Optional: License key for automatic database updates
MAXMIND_LICENSE_KEY=

# ActiveCampaign integration (optional)
KAI_ACTIVECAMPAIGN_ENABLED=false
KAI_ACTIVECAMPAIGN_URL=https://your-account.api-us1.com
KAI_ACTIVECAMPAIGN_API_KEY=
KAI_ACTIVECAMPAIGN_COOKIE=vgo_ee
KAI_ACTIVECAMPAIGN_CACHE_TTL=1440

# Tracker Queue Settings (optional)
KAI_QUEUE_THRESHOLD=5
KAI_QUEUE_SEND_INTERVAL=20000
KAI_QUEUE_PERSIST=true
KAI_QUEUE_STORAGE_KEY=kai_tracker_queue
KAI_QUEUE_MAX_EVENT_AGE=3600000

# Security (optional but recommended for production)
KAI_TRACKING_SECRET=
KAI_TRACKING_ALLOWED_ORIGINS=

# Bot Blacklist Configuration
KAI_BLACKLIST_ENABLED=false
KAI_BLACKLIST_LOGGING=true
KAI_BLACKLIST_LOG_RETENTION=30

# JavaScript tracker
# Use minified tracker.js (recommended for production, ~62% smaller)
KAI_USE_MINIFIED_JS=true
